		{
			"name": "2. Eligibility Endpoint",
			"description": "GET /eligibility/{asin} — single ASIN eligibility check with per-rule detail",
			"item": [
				{
					"name": "GET /eligibility/B00HEON30Y (sample ASIN)",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/eligibility/B00HEON30Y"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"const body = pm.response.json();",
									"pm.test('Has asin', () => pm.expect(body.asin).to.eql('B00HEON30Y'));",
									"pm.test('Has eligible boolean', () => pm.expect(body.eligible).to.be.a('boolean'));",
									"pm.test('Has filter_failed', () => pm.expect(body).to.have.property('filter_failed'));",
									"pm.test('Has checks object', () => pm.expect(body.checks).to.be.an('object'));",
									"pm.test('Checks has referral_fee_pct', () => pm.expect(body.checks).to.have.property('referral_fee_pct'));",
									"pm.test('Checks has rank_or_sales', () => pm.expect(body.checks).to.have.property('rank_or_sales'));",
									"pm.test('Checks has buybox_price', () => pm.expect(body.checks).to.have.property('buybox_price'));",
									"pm.test('Checks has amazon_buybox_pct', () => pm.expect(body.checks).to.have.property('amazon_buybox_pct'));",
									"pm.test('Checks has monthly_sold', () => pm.expect(body.checks).to.have.property('monthly_sold'));",
									"pm.test('Each check has pass/value/threshold', () => {",
									"  const c = body.checks.referral_fee_pct;",
									"  pm.expect(c).to.have.property('pass');",
									"  pm.expect(c).to.have.property('value');",
									"  pm.expect(c).to.have.property('threshold');",
									"});",
									"pm.test('Has computed_roi_pct', () => pm.expect(body).to.have.property('computed_roi_pct'));",
									"pm.test('Has supplier_cost', () => pm.expect(body).to.have.property('supplier_cost'));",
									"pm.test('Has buybox_price', () => pm.expect(body).to.have.property('buybox_price'));",
									"pm.test('Has amazon_buybox_pct', () => pm.expect(body).to.have.property('amazon_buybox_pct'));"
								]
							}
						}
					]
				},
