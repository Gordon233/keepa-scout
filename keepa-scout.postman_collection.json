		{
			"name": "3. Eligibility Batch",
			"description": "POST /eligibility/batch — batch lookup, preserves input order, handles not-found gracefully",
			"item": [
				{
					"name": "POST /eligibility/batch (mixed found + not-found)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/eligibility/batch",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\"asins\": [\"B00HEON30Y\", \"INVALID_ASIN\", \"B010MU00UM\"]}"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"const body = pm.response.json();",
									"pm.test('Has results array', () => pm.expect(body.results).to.be.an('array'));",
									"pm.test('Results count matches input', () => pm.expect(body.results.length).to.eql(3));",
									"pm.test('First result is found', () => pm.expect(body.results[0].found).to.be.true);",
									"pm.test('First result preserves input order', () => pm.expect(body.results[0].asin).to.eql('B00HEON30Y'));",
									"pm.test('Second result is not found', () => {",
									"  pm.expect(body.results[1].asin).to.eql('INVALID_ASIN');",
									"  pm.expect(body.results[1].found).to.be.false;",
									"  pm.expect(body.results[1].data).to.be.null;",
									"});",
									"pm.test('Third result preserves order', () => pm.expect(body.results[2].asin).to.eql('B010MU00UM'));"
								]
							}
						}
					]
				}
			]
		},
