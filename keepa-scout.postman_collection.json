									"const body = pm.response.json();",
									"pm.test('Has answer', () => pm.expect(body.answer).to.be.a('string').and.not.empty);",
									"pm.test('Has sql', () => pm.expect(body.sql).to.be.a('string'));",
									"pm.test('SQL is SELECT', () => pm.expect(body.sql.toUpperCase()).to.include('SELECT'));",
									"pm.test('Has rows', () => pm.expect(body.rows).to.be.an('array'));",
									"pm.test('Has row_count', () => pm.expect(body.row_count).to.be.a('number'));",
									"pm.test('Not out_of_scope', () => pm.expect(body.out_of_scope).to.be.false);"
